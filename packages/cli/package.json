{
  "name": "software-mri",
  "version": "0.1.0",
  "description": "Production readiness diagnosis for your codebase - CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mri": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "echo ok",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mri/core": "workspace:*",
    "@mri/scanner": "workspace:*",
    "@mri/checks": "workspace:*",
    "@mri/scoring": "workspace:*",
    "@mri/reporter": "workspace:*",
    "@mri/ui": "workspace:*",
    "@mri/config": "workspace:*",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/yargs": "^17.0.33"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacobpowaza/software-mri.git"
  },
  "homepage": "https://github.com/jacobpowaza/software-mri#readme",
  "bugs": {
    "url": "https://github.com/jacobpowaza/software-mri/issues"
  },
  "keywords": ["code-quality", "production-readiness", "scanner", "codebase-analysis", "cli"],
  "author": "Jacob Powaza"
}
